# ============================================================
# InfraWrap — Configuration
# ============================================================

# Proxmox VE Connection
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_TOKEN_ID=root@pam!infrawrap
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_ALLOW_SELF_SIGNED=true

# AI / LLM Configuration
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-api03-your-key-here
AI_MODEL=claude-haiku-4-5-20251001

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=your-telegram-user-id

# Web Dashboard
DASHBOARD_PORT=3000

# Autopilot
AUTOPILOT_ENABLED=false
AUTOPILOT_POLL_INTERVAL_MS=30000
